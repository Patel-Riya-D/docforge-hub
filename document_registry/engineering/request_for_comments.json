{
  "document_name": "Request for Comments (RFC)",
  "department": "Engineering",
  "internal_type": "REPORT",
  "risk_level": "MEDIUM",
  "approval_required": true,
  "versioning": { "review_cycle": "annual" },
   "input_groups": [
    {
      "group_name": "Proposal Overview",
      "fields": [
        {
          "key": "problem_statement",
          "label": "Problem Statement",
          "type": "textarea",
          "required": true
        },
        {
          "key": "proposed_solution_summary",
          "label": "Proposed Solution Summary",
          "type": "textarea",
          "required": true
        },
        {
          "key": "affected_systems",
          "label": "Affected Systems / Services",
          "type": "textarea",
          "required": true
        },
        {
          "key": "approval_required_from",
          "label": "Approval Required From (Role/Team)",
          "type": "text",
          "required": true
        }
      ]
    },
    {
      "group_name": "Risk & Impact",
      "fields": [
        {
          "key": "risk_level",
          "label": "Technical Risk Level (Low/Medium/High)",
          "type": "text",
          "required": true
        },
        {
          "key": "rollback_strategy_defined",
          "label": "Is Rollback Strategy Defined?",
          "type": "boolean",
          "required": true
        }
      ]
    }
  ],
  "sections": [
    { "name": "title", "mandatory": true },
    { "name": "summary", "mandatory": true },
    { "name": "methodology", "mandatory": true },
    { "name": "analysis", "mandatory": true },
    { "name": "findings", "mandatory": true },
    { "name": "conclusion", "mandatory": true },

    { "name": "alternatives considered", "mandatory": false },
    { "name": "security considerations", "mandatory": false }
  ],
  "allowed_formats": ["notion", "docx"]
}
