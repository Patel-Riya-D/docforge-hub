{
  "document_name": "Bug Report",
  "department": "Quality Assurance",
  "internal_type": "REPORT",
  "risk_level": "MEDIUM",
  "approval_required": false,
  "versioning": { "review_cycle": "per-issue" },
     "input_groups": [
    {
      "group_name": "Bug Details",
      "fields": [
        {
          "key": "severity_level",
          "label": "Severity Level",
          "type": "text",
          "required": true
        },
        {
          "key": "reproduction_steps",
          "label": "Steps to Reproduce",
          "type": "textarea",
          "required": true
        }
      ]
    }
  ],
  "sections": [
    { "name": "Summary", "mandatory": true },
    { "name": "Description", "mandatory": true },
    { "name": "Severity", "mandatory": true },
    { "name": "Priority", "mandatory": true },
    { "name": "Steps to Reproduce", "mandatory": true },
    { "name": "Expected Result", "mandatory": true },
    { "name": "Actual Result", "mandatory": true },
    { "name": "Environment", "mandatory": true },
    { "name": "Attachments", "mandatory": false }
  ],
  "allowed_formats": ["notion"]
}
