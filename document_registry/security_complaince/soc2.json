        },
        {
          "key": "report_type",
          "label": "Report Type (Type I / Type II)",
          "type": "text",
          "required": true
        },
        {
          "key": "audit_firm",
          "label": "Audit Firm Name",
          "type": "text",
          "required": true
        },
        {
          "key": "audit_frequency",
          "label": "Audit Frequency",
          "type": "text",
          "required": true
        }
      ]
    }
  ],

  "sections": [
    { "name": "Management Assertion Letter", "mandatory": true },
    { "name": "Auditor’s Opinion", "mandatory": false },
