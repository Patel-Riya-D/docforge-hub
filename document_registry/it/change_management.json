{
  "document_name": "Change Management Template",
  "department": "IT Operations",
  "internal_type": "TEMPLATE",
  "risk_level": "MEDIUM",
  "approval_required": true,
  "versioning": {
    "review_cycle": "per-change"
  },
   "input_groups": [
    {
      "group_name": "Change Categories",
      "fields": [
        {
          "key": "change_types",
