          "type": "textarea",
          "required": true
        }
      ]
    },
    {
      "group_name": "Approval Workflow",
      "fields": [
        {
          "key": "change_approval_process",
          "label": "Change Approval Process",
          "type": "textarea",
          "required": true
        }
      ]
    }
  ],  
  "sections": [
    { "name": "Title", "mandatory": true },
    { "name": "Summary", "mandatory": true },
    { "name": "Change Details", "mandatory": true },
    { "name": "Change Plans", "mandatory": true },
    { "name": "Change Implementation Tasks", "mandatory": true },
    { "name": "Communications", "mandatory": true },
    { "name": "Post-Implementation Review", "mandatory": true }
  ],
  "allowed_formats": ["notion", "pdf"]
}
