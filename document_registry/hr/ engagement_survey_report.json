{
  "document_name": "Engagement Survey Report",
  "department": "HR",
  "internal_type": "REPORT",
  "risk_level": "MEDIUM",
  "approval_required": true,
  "versioning": { "review_cycle": "annual" },
  "input_groups": [
    {
      "group_name": "Survey Overview",
      "fields": [
        {
          "key": "survey_period",
          "label": "Survey Period",
          "type": "text",
          "required": true
        },
        {
          "key": "participation_rate",
          "label": "Participation Rate (%)",
          "type": "number",
          "required": true
        }
      ]
    },
    {
      "group_name": "Key Findings",
      "fields": [
        {
          "key": "top_strengths",
          "label": "Top Strength Areas",
          "type": "textarea",
          "required": true
        },
        {
          "key": "improvement_areas",
          "label": "Areas for Improvement",
          "type": "textarea",
          "required": true
        }
      ]
    }
  ],
  "sections": [
    { "name": "Title", "mandatory": true },
    { "name": "Executive Summary", "mandatory": true },
    { "name": "Participation Rates & Demographics", "mandatory": true },
    { "name": "Overall Company Scores & Trends", "mandatory": true },
    { "name": "Department / Team Comparisons", "mandatory": true },
    { "name": "Driver Analysis: Strengths", "mandatory": false },
    { "name": "Driver Analysis: Areas for Improvement", "mandatory": false },
    { "name": "Qualitative Feedback (Thematic)", "mandatory": false },
    { "name": "Key Recommendations & Action Plan", "mandatory": true },
    { "name": "Next Steps & Timelines", "mandatory": true }
  ],
  "allowed_formats": ["notion", "docx", "pdf"]
}
