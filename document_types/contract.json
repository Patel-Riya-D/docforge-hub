        { "key": "party_b", "label": "Party B Name", "type": "text", "required": true },
        { "key": "effective_date", "label": "Effective Date", "type": "date", "required": true },
        { "key": "jurisdiction", "label": "Governing Law / Jurisdiction", "type": "text", "required": true }
      ]
    }
  ],
  "supported_formats": ["pdf", "docx"]
