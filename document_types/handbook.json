{
  "internal_type": "HANDBOOK",

  "default_risk_level": "MEDIUM",
  "approval_required": true,

  "versioning_strategy": "strict",

  "mandatory_sections": [
    "introduction",
    "company_overview",
    "mission_and_values",
    "employment_policies_summary",
    "code_of_conduct",
    "compensation_and_benefits_overview",
    "workplace_guidelines",
    "leave_and_time_off",
    "performance_and_development",
    "compliance_and_ethics",
    "acknowledgment",
    "review"
  ],

  "common_input_groups": [
    {
      "group_name": "General Handbook Information",
      "fields": [
        {
          "key": "effective_date",
          "label": "Effective Date",
          "type": "date",
          "required": true
        },
        {
          "key": "handbook_owner_role",
          "label": "Handbook Owner Role",
          "type": "text",
          "required": true
        },
        {
          "key": "organization_size",
          "label": "Organization Size",
          "type": "select",
          "options": ["Startup (0-50)", "Scale-up (50-200)", "Enterprise (200+)"],
          "required": false
        },
        {
          "key": "primary_region",
          "label": "Primary Operating Region",
          "type": "text",
          "required": false
        },
        {
          "key": "review_frequency",
          "label": "Review Frequency",
          "type": "text",
          "required": true
        }
      ]
    },
    {
      "group_name": "Compliance Requirements",
      "fields": [
        {
          "key": "include_gdpr_reference",
          "label": "Include GDPR Considerations",
          "type": "boolean",
          "required": false
        },
        {
          "key": "include_soc2_reference",
          "label": "Include SOC 2 References",
          "type": "boolean",
          "required": false
        },
        {
          "key": "include_local_labor_law_reference",
          "label": "Include Local Labor Law References",
          "type": "boolean",
          "required": false
        }
      ]
    }
  ],

  "supported_formats": ["notion", "pdf", "docx"]
}
